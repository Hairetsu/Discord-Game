DISCORD_TOKEN=replace-with-your-bot-token
DISCORD_CLIENT_ID=replace-with-your-application-client-id
# Optional: register slash commands to one test guild instantly.
DISCORD_GUILD_ID=replace-with-test-guild-id
# Optional: where SQLite data is stored.
DATABASE_PATH=./data/heist-bank.sqlite
# Required for /market commands that use real stock quotes.
ALPHA_VANTAGE_API_KEY=replace-with-alpha-vantage-key
